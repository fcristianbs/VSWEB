{ pkgs, ... }: {
  channel = "stable-23.11";
  packages = [
    pkgs.python3
    pkgs.python3Packages.pip
  ];
  idx = {
    extensions = [
      "ms-python.python"
    ];
    previews = {
      enable = true;
      previews = {
        web = {
          command = ["python3" "app.py" "--port" "$PORT" "--host" "0.0.0.0"];
          manager = "web";
        };
      };
    };
  };
}